# Node / Package Manager
node_modules/
.pnpm-store/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
.next/
out/
build/
next-env.d.ts

# Vercel
.vercel

# Env (커밋 금지 — example만 허용)
.env*
!.env.example

# Tests
coverage/
test-results/
playwright-report/

# Visual regression — 베이스라인 PNG는 CI Linux에서 commit 대상.
# 로컬 macOS 에서 생성된 actual/diff 임시 결과물만 무시 (베이스라인은 그대로 commit 가능)
e2e/visual/__screenshots__/*-actual.png
e2e/visual/__screenshots__/*-diff.png

# PWA build artifacts (regenerated by next build, via @serwist/next)
public/sw.js
public/sw.js.map
public/swe-worker-*.js
public/workbox-*.js

# Compiled prompts (빌드 산출 — main에 박지 않음)
lib/prompts/_compiled/*
!lib/prompts/_compiled/.gitkeep

# IDE / OS
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
*.pem
*.log

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TypeScript
*.tsbuildinfo
